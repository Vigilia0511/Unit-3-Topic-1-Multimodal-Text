let score=0;

function buildQuiz(){
  const c=document.getElementById('quiz-container');
  c.innerHTML='';
  questions.forEach((q,i)=>{
    const div=document.createElement('div');
    div.className='qcard';
    div.innerHTML=`<div class="qnum">Question ${i+1} of ${questions.length}</div><div class="qtxt">${q.q}</div><div class="choices" id="ch-${i}">${q.choices.map((ch,j)=>`<div class="choice" data-idx="${j}" onclick="answer(${i},${j})">${ch}</div>`).join('')}</div><div class="fb" id="fb-${i}"></div>`;
    c.appendChild(div);
  });
  updateScore();
}

function answer(qi,ci){
  const q=questions[qi];
  const ch=document.getElementById(`ch-${qi}`);
  const fb=document.getElementById(`fb-${qi}`);
  ch.querySelectorAll('.choice').forEach(c=>c.classList.add('disabled'));
  if(ci===q.correct){
    ch.querySelectorAll('.choice')[ci].classList.add('correct');
    fb.textContent='✓ Correct! '+q.exp;
    fb.className='fb show ok';
    score++;
  } else {
    ch.querySelectorAll('.choice')[ci].classList.add('wrong');
    ch.querySelectorAll('.choice')[q.correct].classList.add('correct');
    fb.textContent='✗ Not quite. '+q.exp;
    fb.className='fb show no';
  }
  updateScore();
}

function updateScore(){
  document.getElementById('score-display').textContent=`${score} / ${questions.length}`;
  const pct=Math.round((score/questions.length)*100);
  document.getElementById('score-fill').style.width=pct+'%';
  let msg='';
  if(score===questions.length) msg='Perfect score! Excellent work!';
  else if(pct>=80) msg='Great job! Almost there.';
  else if(pct>=50) msg='Good effort. Keep reviewing!';
  else if(score>0) msg='Keep going, you can do it!';
  document.getElementById('score-msg').textContent=msg;
}

function resetQuiz(){score=0;buildQuiz();}

function showTab(id,el){
  document.querySelectorAll('.sec').forEach(s=>s.classList.remove('active'));
  document.querySelectorAll('.tab').forEach(t=>t.classList.remove('active'));
  document.getElementById(id).classList.add('active');
  el.classList.add('active');
}

buildQuiz();
</script>
